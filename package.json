{
  "name": "foam-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "BSD-3-Clause",
  "workspaces": [
    "src/*"
  ],
  "scripts": {
    "alphabetize": "node src/foam/scripts/alphabetizePackageJson.js",
    "android": "bun run --cwd src/foam android",
    "commit": "cz",
    "format:check": "bun run prettier:check",
    "format:fix": "bun run prettier:fix",
    "ios": "bun run --cwd src/foam ios",
    "lint": "bun run --cwd src/foam lint",
    "preinstall": "[ -n \"$CI\" ] || (only-allow bun && node ./src/foam/scripts/commit-hooks)",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "proxy": "bun run --cwd src/local-proxy dev",
    "start": "bun run --cwd src/foam start",
    "test": "bun run --cwd src/foam test",
    "ts:check": "bun run --cwd src/foam ts:check",
    "website": "bun run --cwd src/player-website dev"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "9.1.7",
    "lint-staged": "^15.4.3",
    "only-allow": "^1.2.1",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json,md,yml,yaml}": "bunx prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=20"
  },
  "engineStrict": true,
  "bun": {
    "overrides": {
      "uuid": "3.4.0"
    }
  },
  "patchedDependencies": {
    "@legendapp/state@2.1.15": "src/foam/patches/@legendapp%2Fstate@2.1.15.patch",
    "@legendapp/list@3.0.4": "src/foam/patches/@legendapp%2Flist@3.0.4.patch",
    "expo-image@57.0.0": "src/foam/patches/expo-image@57.0.0.patch"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@sentry/cli",
    "@shopify/react-native-skia",
    "core-js",
    "core-js-pure",
    "esbuild",
    "protobufjs",
    "sharp"
  ]
}
