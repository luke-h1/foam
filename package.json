{
  "name": "foam",
  "version": "0.1.0",
  "private": true,
  "license": "BSD-3-Clause",
  "main": "index.js",
  "scripts": {
    "alphabetize": "node scripts/alphabetizePackageJson.js",
    "android": "EXPO_PUBLIC_APP_VARIANT=development expo run:android",
    "android:production": "EXPO_PUBLIC_APP_VARIANT=production expo run:android --variant release",
    "ios:production-testflight": "EXPO_PUBLIC_APP_VARIANT=testflight expo run:ios --configuration Release",
    "atlas:analyze": "expo-atlas",
    "atlas:analyze:file": "expo-atlas .expo/atlas.jsonl",
    "atlas:export": "EXPO_UNSTABLE_ATLAS=true expo export --platform all",
    "build:debug:android": "cd android && ./gradlew assembleDebug -DtestBuildType=debug -Dorg.gradle.jvmargs=-Xmx4g",
    "build:debug:ios": "cd ios && DISABLE_RNREPO=true pod install && cd .. && xcodebuild ONLY_ACTIVE_ARCH=YES -workspace ios/Foam.xcworkspace -UseNewBuildSystem=YES -scheme Foam -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -quiet",
    "build:local:production:ios": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=production expo prebuild && DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=production expo run:ios",
    "clean": "rm -rf ios android .expo node_modules",
    "commit": "cz",
    "deploy": "./scripts/deploy.sh",
    "e2e:build:android": "eas build --profile e2e --platform android --local",
    "e2e:build:ios": "eas build --profile e2e --platform ios --local",
    "e2e:build:ios:sim": "APP_VARIANT=e2e xcodebuild ONLY_ACTIVE_ARCH=YES -workspace ios/Foamdev.xcworkspace -scheme Foamdev -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -quiet",
    "e2e:dev:android": "EXPO_PUBLIC_APP_VARIANT=e2e expo run:android",
    "e2e:dev:ios": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=e2e expo run:ios",
    "e2e:mock-server": "bun e2e/mock-server/server.ts",
    "e2e:mock-server:dev": "bun --watch e2e/mock-server/server.ts",
    "e2e:prebuild": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=e2e expo prebuild",
    "e2e:prebuild:clean": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=e2e expo prebuild --clean",
    "e2e:test": "./scripts/e2e-maestro.sh",
    "e2e:test:smoke": "./scripts/e2e-maestro.sh --include-tags smoke",
    "env:pull": "./scripts/pull-env.sh",
    "expo:modules:build:ios": "node scripts/expo-modules-provider-ios.mjs",
    "expo:modules:jsi:clean": "PODS_ROOT=\"$PWD/ios/Pods\" ./node_modules/expo-modules-jsi/apple/scripts/build-xcframework.sh --clean",
    "expo:modules:resolve:ios": "expo-modules-autolinking resolve --platform apple",
    "expo:modules:search:ios": "expo-modules-autolinking search --platform apple",
    "export": "bunx expo export",
    "fingerprint:android": "npx expo-updates fingerprint:generate --platform android | jq -r '.hash' | xargs -n 1 echo 'fingerprint:'",
    "fingerprint:ios": "npx expo-updates fingerprint:generate --platform ios | jq -r '.hash' | xargs -n 1 echo 'fingerprint:'",
    "format:check": "bun run prettier:check",
    "format:fix": "bun run prettier:fix",
    "gen-env": "gen-env-types .env -o src/types/env.d.ts -e .",
    "gen:emoji": "node scripts/generateEmojiDataset.mjs",
    "gen:paints": "node scripts/refreshPaintFixtures.mjs",
    "gql:codegen": "graphql-codegen",
    "icons:optimize": "svgo -f ./assets/icons",
    "ios": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=development expo run:ios",
    "ios:production": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=production expo run:ios --configuration Release",
    "ios:sourcekit:changelog": "cd modules/changelog/ios && xcode-build-server config -workspace ../../../ios/Foamdev.xcworkspace -scheme Changelog",
    "lint": "bun run lint:check",
    "lint:ast-grep": "ast-grep scan",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "metadata:push": "EXPO_PUBLIC_APP_VARIANT=production eas metadata:push --profile production",
    "ota": "./scripts/release-ota.sh",
    "ota:check": "./scripts/ota-compat-check.sh",
    "perf:chat:ios": "bash scripts/perf/capture-chat-instruments.sh",
    "perf:chat:ios:export": "bash scripts/perf/export-instruments-trace.sh",
    "perf:chat:rn": "bash scripts/perf/capture-chat-react-devtools.sh",
    "perf:chat:rn:diff": "bash scripts/perf/diff-react-devtools-profiles.sh",
    "prebuild": "DISABLE_RNREPO=true EXPO_PUBLIC_APP_VARIANT=development expo prebuild",
    "prebuild:android": "npx expo prebuild -p android",
    "prebuild:ios": "DISABLE_RNREPO=true npx expo prebuild -p ios",
    "preinstall": "[ -n \"$CI\" ] || (only-allow bun && node ./scripts/commit-hooks)",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "release:github": "./scripts/release-github.sh",
    "start": "EXPO_PUBLIC_APP_VARIANT=development expo start --dev-client",
    "start:atlas": "EXPO_UNSTABLE_ATLAS=true EXPO_PUBLIC_APP_VARIANT=development expo start --dev-client",
    "start:atlas:production": "EXPO_UNSTABLE_ATLAS=true EXPO_PUBLIC_APP_VARIANT=development expo start --no-dev",
    "start:proxy": "bun --watch local-proxy/proxy.ts",
    "storybook:generate": "sb-rn-get-stories --config-path .rnstorybook",
    "storybook:preview": "EXPO_PUBLIC_APP_VARIANT=development expo start --web",
    "submit": "./scripts/submit.sh",
    "test": "jest",
    "test:ast-grep": "ast-grep test",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --coverage",
    "test:perf": "reassure measure",
    "test:snapshot": "jest --updateSnapshot",
    "test:watch": "jest --watch",
    "ts:check": "tsc --noEmit",
    "use-build-number": "./scripts/useBuildNumberEnv.sh",
    "use-build-number-with-bump": "./scripts/useBuildNumberEnvWithBump.sh",
    "web": "expo start --web"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.2",
    "@bacons/apple-colors": "^0.0.8",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo-google-fonts/source-code-pro": "^0.4.0",
    "@expo/metro-runtime": "~57.0.2",
    "@expo/ui": "~57.0.1",
    "@legendapp/list": "3.0.4",
    "@legendapp/state": "^2.1.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@react-native-firebase/app": "^23.7.0",
    "@react-native-firebase/installations": "^23.7.0",
    "@react-native-firebase/remote-config": "^23.7.0",
    "@rnrepo/expo-config-plugin": "^0.3.1",
    "@sentry/react-native": "8.14.1",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@statsig/react-native-bindings": "3.33.2",
    "@swmansion/react-native-bottom-sheet": "0.14.1",
    "@tanstack/react-query": "5.100.9",
    "app-icon-badge": "0.1.2",
    "date-fns": "4.1.0",
    "dayjs": "^1.11.13",
    "expo": "^57.0.0",
    "expo-application": "~57.0.0",
    "expo-auth-session": "~57.0.1",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.2",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.2",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-insights": "~57.0.1",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-media-library": "~57.0.0",
    "expo-network": "~57.0.0",
    "expo-pretext": "^1.1.0",
    "expo-quick-actions": "^6.0.1",
    "expo-router": "~57.0.2",
    "expo-screen-orientation": "~57.0.0",
    "expo-secure-store": "~57.0.0",
    "expo-sensors": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.3",
    "i18next": "^26.3.1",
    "jest-junit": "^16.0.0",
    "pressto": "0.6.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-boost": "^1.3.0",
    "react-native-compressor": "2.0.2",
    "react-native-device-info": "15.0.2",
    "react-native-ease": "0.7.2",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-legal": "1.6.3",
    "react-native-logs": "5.6.0",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "0.35.7",
    "react-native-pager-view": "8.0.2",
    "react-native-react-query-devtools": "1.5.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-tab-view": "^4.2.2",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "react-server-dom-webpack": "~19.2.4",
    "sonner-native": "0.25.0",
    "twemoji": "14.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.27.1",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "^9.39.4",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@graphql-codegen/typescript-react-apollo": "^4.4.0",
    "@react-native-community/cli": "20.0.1",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@rozenite/expo-atlas-plugin": "1.11.0",
    "@rozenite/metro": "1.11.0",
    "@rozenite/network-activity-plugin": "1.11.0",
    "@rozenite/performance-monitor-plugin": "1.11.0",
    "@rozenite/react-navigation-plugin": "1.11.0",
    "@rozenite/require-profiler-plugin": "1.11.0",
    "@rozenite/storage-plugin": "1.11.0",
    "@rozenite/tanstack-query-plugin": "1.11.0",
    "@storybook/addon-ondevice-actions": "^10.4.2",
    "@storybook/addon-ondevice-controls": "^10.4.2",
    "@storybook/addon-react-native-web": "^0.0.29",
    "@storybook/react": "^10.3.6",
    "@storybook/react-native": "^10.4.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.1.0",
    "@types/react": "~19.2.10",
    "@welldone-software/why-did-you-render": "10.0.1",
    "babel-jest": "^30.0.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-cli": "^11.0.0",
    "eas-build-cache-provider": "20.0.0",
    "emojibase-data": "17.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-doctor": "0.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-reanimated": "^2.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "expo-atlas": "^0.4.3",
