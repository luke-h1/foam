# Expo
.expo/
dist/
web-build/
action-build
build-artifacts/
artifacts/
docs/

# sibling workspaces: exclude their payload but keep the package.json
# manifests so bun install can still resolve the workspace globs on
# remote EAS builds
src/player-website/*
!src/player-website/package.json
src/local-proxy/*
!src/local-proxy/package.json
# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

!.env.example
/src/foam/ios
/src/foam/android
src/foam/modules/*/android/build

# Turborepo
.turbo


# macOS
.DS_Store

