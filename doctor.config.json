{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "files": [
      "__mocks__/**",
      "**/__tests__/**",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx"
    ],
    "overrides": [
      {
        "files": ["package.json"],
        "rules": ["deslop/unused-dependency", "deslop/unused-dev-dependency"]
      }
    ]
  },
  "rules": {
    "react-doctor/react-compiler-no-manual-memoization": "off",
    "react-doctor/rn-no-raw-text": "warn"
  }
}
