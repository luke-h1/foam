diff --git a/react-native.js b/react-native.js
index 74a8b9e70fde06482b9c9fd4720a497a0895e09f..dd2073be52d3bdb3cbac90474310645bd5b077ea 100644
--- a/react-native.js
+++ b/react-native.js
@@ -2226,11 +2226,16 @@ function doMaintainScrollAtEnd(ctx) {
               animated: maintainScrollAtEnd.animated
             });
           }
+          // PATCH(foam): upstream keeps `maintainingScrollAtEnd` locked for 500ms after
+          // an animated re-pin, and threshold checks are skipped while it is set. Busy
+          // chats deliver a message every 50-200ms, so follow-up re-pins were suppressed
+          // and rows piled up below the fold until the flag cleared. 150ms still outlasts
+          // the scroll settle while re-arming within chat message cadence.
           setTimeout(
             () => {
               state.maintainingScrollAtEnd = false;
             },
-            maintainScrollAtEnd.animated ? 500 : 0
+            maintainScrollAtEnd.animated ? 150 : 0
           );
         } else {
           state.maintainingScrollAtEnd = false;
